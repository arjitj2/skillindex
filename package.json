{
  "name": "skillindex",
  "version": "0.2.2",
  "description": "Local macOS app for keeping your AI setup portable, inspectable, and aligned across agents.",
  "author": "Arjit Jaiswal",
  "license": "Apache-2.0",
  "private": true,
  "homepage": "https://skillindex.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arjitj2/skillindex.git"
  },
  "bugs": {
    "url": "https://github.com/arjitj2/skillindex/issues"
  },
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist:dev": "SKILL_INDEX_BUILD_FLAVOR=dev-alpha pnpm build && electron-builder --mac zip --config electron-builder.dev.yml",
    "dist:mac": "SKILL_INDEX_BUILD_FLAVOR=standard pnpm build && electron-builder --mac --universal --config electron-builder.yml --publish=never",
    "dist:mac:publish": "SKILL_INDEX_BUILD_FLAVOR=standard pnpm build && electron-builder --mac --universal --config electron-builder.yml --publish=always",
    "dist:mac:unsigned": "SKILL_INDEX_BUILD_FLAVOR=standard pnpm build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --universal --config electron-builder.yml --publish=never -c.mac.identity=null -c.mac.notarize=false -c.mac.forceCodeSigning=false",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^4.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^7.3.5",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "overrides": {
      "fast-uri": "3.1.2",
      "hono": "4.12.25",
      "ip-address": "10.2.0",
      "postcss": "8.5.14",
      "tmp": "0.2.7",
      "electron-vite>esbuild": "0.28.1",
      "vite>esbuild": "0.28.1"
    }
  }
}
